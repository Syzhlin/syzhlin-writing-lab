# Gemini API Key (원고 다듬기 AI 기능)
GEMINI_API_KEY=""

# Google 서비스 계정 (Google Docs 내보내기에 필요)
# 설정 방법:
# 1. Google Cloud Console에서 서비스 계정 생성
# 2. Google Docs API + Google Drive API 활성화
# 3. 서비스 계정 키(JSON) 발급
# 4. 아래 값을 Vercel 환경변수에 등록
# 5. 내보낼 구글 드라이브 폴더를 서비스 계정 이메일과 공유

GOOGLE_CLIENT_EMAIL="your-service-account@project.iam.gserviceaccount.com"
# GOOGLE_PRIVATE_KEY: JSON 키 파일의 private_key 값 전체 붙여넣기 (-----BEGIN 포함)
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
# GOOGLE_DOCS_FOLDER_ID: 구글 드라이브 폴더 URL의 마지막 ID (선택사항)
GOOGLE_DOCS_FOLDER_ID=""
